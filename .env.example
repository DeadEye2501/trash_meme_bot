TELEGRAM_TOKEN=secret
TELEGRAM_URL=t.me/trash_meme_bot
MAX_MESSAGE_LENGTH=4096
TEMP_DIR=path/to/temp/dir/

PARSE_PIKABU=1
PARSE_REDDIT=1
PARSE_X=1
PARSE_PINTEREST=1
PARSE_INSTAGRAM=1

REDDIT_CLIENT_ID=secret
REDDIT_CLIENT_SECRET=secret
REDDIT_USER_AGENT="personal use script by u/trash_meme_bot"

# Optional: forwarded to Pikabu/Pinterest/Reddit HTTP requests.
# Leave unset to send default requests-library headers.
HTTP_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/127.0.0.0 Safari/537.36"
HTTP_ACCEPT_LANGUAGE="en-US,en;q=0.9"
